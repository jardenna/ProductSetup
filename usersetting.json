{
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "search.useGlobalIgnoreFiles": true,
  "git.confirmSync": false,
  "editor.lightbulb.enabled": "on",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.preferences.quoteStyle": "single",
  "typescript.preferences.quoteStyle": "single",
  "typescript.validate.enable": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "git.enableSmartCommit": true,
  "workbench.iconTheme": "material-icon-theme",
  "files.exclude": {
    "**/.vscode": true
  },
  "typescript.preferences.autoImportFileExcludePatterns": [
    "node_modules/react-day-picker",
    "node_modules/react-select/animated"
  ],
  "workbench.colorCustomizations": {
    "editorError.foreground": "#df1021",
    "editorWarning.foreground": "#d87315",
    "list.errorForeground": "#b96506",
    "list.warningForeground": "#c06c0d"
  },
  "html.format.unformatted": "",
  "editor.accessibilitySupport": "off",
  "emmet.showSuggestionsAsSnippets": true,

  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "vue",
    "markdown",
    "cjs"
  ],
  "eslint.nodePath": "",
  "hediet.vscode-drawio.resizeImages": null,
  "typescript.format.semicolons": "insert",
  "reactSnippets.settings.prettierEnabled": true,
  "eslint.rules.customizations": [],
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.nodeEnv": "",
  "scss.format.spaceAroundSelectorSeparator": true,
  "scss.format.enable": true,
  "workbench.settings.applyToAllProfiles": [],
  "git.openRepositoryInParentFolders": "always",
  "diffEditor.maxComputationTime": 0,
  "grunt.autoDetect": "on",
  "emmet.preferences": {},
  "editor.defaultFoldingRangeProvider": "vscode.typescript-language-features",
  "workbench.colorTheme": "Visual Studio Light",
  "workbench.startupEditor": "none",
  "editor.suggest.localityBonus": true,
  "editor.suggest.showDeprecated": false,
  "gitlens.views.remotes.branches.layout": "list",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescriptreact": true
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "gitlens.launchpad.indicator.enabled": false
}
